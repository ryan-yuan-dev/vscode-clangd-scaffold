{
    "version": 8,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 22,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "macOS",
            "displayName": "macOS",
            "description": "MacOS 上编译 macOS 项目",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "/usr/bin/clang",
                "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_VERBOSE_MAKEFILE": true,
                "MACOS": "ON"
            }
        },
        {
            "name": "iOS",
            "displayName": "iOS",
            "description": "macOS 上编译 iOS 项目",
            "generator": "Xcode",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "PLATFORM": "OS64",
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_SYSTEM_VERSION": "13.0",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_SYSROOT": "iphoneos",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_VERBOSE_MAKEFILE": true,
                "CMAKE_TOOLCHAIN_FILE": "${workspaceFolder}/ios-cmake/ios.toolchain.cmake",
                "IOS": "ON"
            }
        },
        {
            "name": "Android-macOS",
            "hidden": true,
            "displayName": "macOS 上交叉编译 Android 项目",
            "description": "macOS 上交叉编译 Android 项目",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
                "ANDROID_PLATFORM": "android-24",
                "ANDROID_STL": "c++_static",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_VERBOSE_MAKEFILE": true
            }
        },
        {
            "name": "Android-arm64-macOS",
            "description": "macOS 上交叉编译 Android arm64 项目",
            "inherits": [
                "Android-macOS"
            ],
            "cacheVariables": {
                "ANDROID_ABI": "arm64-v8a"
            }
        }
    ]
}